  id                   String    @id @default(uuid())
  eventId              String    @unique @map("event_id")
  event                Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  registrationCount    Int       @default(0) @map("registration_count")
  participationCount   Int       @default(0) @map("participation_count")
  attendanceCount      Int       @default(0) @map("attendance_count")
  completionPercentage Float?    @map("completion_percentage")
  certificatesIssued   Int       @default(0) @map("certificates_issued")
  deletedAt            DateTime? @map("deleted_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  @@map("event_statistics")
}

model EventLog {
  id        String   @id @default(uuid())
  eventId   String   @map("event_id")
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  action    String   // "CREATED", "UPDATED", "PUBLISHED", "REGISTRATION", "CANCELLED", "COMPLETED"
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  details   String?
  timestamp DateTime @default(now())

  @@map("event_logs")
}

// ────────────────────────────────────────────────────────────────
// Announcements & Notifications (Part 12) - New Models
// ────────────────────────────────────────────────────────────────

model AnnouncementTarget {
  id             String       @id @default(uuid())
  announcementId String       @map("announcement_id")
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  targetType     String       @map("target_type") // e.g. "COLLEGE", "DEPARTMENT", "SEMESTER", "DIVISION", "STUDENT", "TEACHER"
  targetId       String?      @map("target_id")   // ID of specific entity (deptId, etc.)
  deletedAt      DateTime?    @map("deleted_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@map("announcement_targets")
}

model AnnouncementAttachment {
  id             String       @id @default(uuid())
  announcementId String       @map("announcement_id")
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  fileUrl        String       @map("file_url")
  fileName       String       @map("file_name")
  fileType       String       @map("file_type")
  fileSize       Int?         @map("file_size")
  deletedAt      DateTime?    @map("deleted_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@map("announcement_attachments")
}

model NotificationQueue {
  id               String        @id @default(uuid())
  notificationId   String?       @map("notification_id")
  notification     Notification? @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  recipientType    String        @map("recipient_type") // "EMAIL" | "PUSH" | "SMS"
  recipientAddress String        @map("recipient_address")
  subject          String?
  body             String
  status           String        @default("PENDING") // "PENDING" | "SENT" | "FAILED"
  retryCount       Int           @default(0) @map("retry_count")
  errorLog         String?       @map("error_log")
  createdAt        DateTime      @default(now()) @map("created_at")
  sentAt           DateTime?     @map("sent_at")

  @@map("notification_queue")
}

model NotificationTemplate {
  id              String   @id @default(uuid())
  name            String   @unique
  subjectTemplate String?  @map("subject_template")
  bodyTemplate    String   @map("body_template")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("notification_templates")
}

model NotificationRecipient {
  id             String       @id @default(uuid())
  notificationId String       @map("notification_id")
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  userId         String       @map("user_id")
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  isDelivered    Boolean      @default(false) @map("is_delivered")
  deliveredAt    DateTime?    @map("delivered_at")
  isRead         Boolean      @default(false) @map("is_read")
  readAt         DateTime?    @map("read_at")

  @@map("notification_recipients")
}

model NotificationPreference {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  allowPush Boolean  @default(true) @map("allow_push")
  allowEmail Boolean @default(true) @map("allow_email")
  allowSMS  Boolean  @default(false) @map("allow_sms")
  allowInApp Boolean @default(true) @map("allow_in_app")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("notification_preferences")
}

model NotificationLog {
  id             String        @id @default(uuid())
  userId         String        @map("user_id")
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  notificationId String?       @map("notification_id")
  notification   Notification? @relation(fields: [notificationId], references: [id], onDelete: SetNull)
  channel        String        // "EMAIL" | "PUSH" | "SMS" | "IN_APP"
  status         String        // "SENT" | "DELIVERED" | "FAILED" | "OPENED"
  errorDetails   String?       @map("error_details")
  timestamp      DateTime      @default(now())

  @@map("notification_logs")
}

model BroadcastMessage {
  id         String         @id @default(uuid())
  collegeId  String         @map("college_id")
  college    College        @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  senderId   String         @map("sender_id")
  sender     User           @relation(fields: [senderId], references: [id], onDelete: Cascade)
  title      String
  body       String
  targetType String         @map("target_type") // "ALL_STUDENTS" | "DEPARTMENT" | "SEMESTER" | "DIVISION" | "TEACHERS"
  targetId   String?        @map("target_id")
  sentAt     DateTime       @default(now()) @map("sent_at")
  logs       BroadcastLog[]

  @@map("broadcast_messages")
}

model BroadcastLog {
  id             String           @id @default(uuid())
  broadcastId    String           @map("broadcast_id")
  broadcast      BroadcastMessage @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  recipientCount Int              @default(0) @map("recipient_count")
  deliveredCount Int              @default(0) @map("delivered_count")
  readCount      Int              @default(0) @map("read_count")
  failedCount    Int              @default(0) @map("failed_count")
  createdAt      DateTime         @default(now()) @map("created_at")

  @@map("broadcast_logs")
}

