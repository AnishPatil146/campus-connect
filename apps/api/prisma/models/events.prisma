// ────────────────────────────────────────────────────────────────
// Chapter 12 — Events
// ────────────────────────────────────────────────────────────────

model Event {
  id                   String         @id @default(uuid())
  collegeId            String         @map("college_id")
  college              College        @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  createdById          String         @map("created_by_id")
  createdBy            User           @relation("EventCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  categoryId           String?        @map("category_id")
  category             EventCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  title                String
  description          String?
  venue                String?
  startDatetime        DateTime       @map("start_datetime")
  endDatetime          DateTime?      @map("end_datetime")
  registrationStart    DateTime?      @map("registration_start")
  registrationEnd      DateTime?      @map("registration_end")
  maximumParticipants  Int?           @map("maximum_participants")
  registrationRequired Boolean        @default(false) @map("registration_required")
  approvalRequired     Boolean        @default(false) @map("approval_required")
  status               EventStatus    @default(DRAFT)

  registrations EventRegistration[]
  participants  EventParticipant[]
  gallery       EventGallery[]
  documents     EventDocument[]
  attendance    EventAttendance[]
  results       EventResult[]
  certificates  EventCertificate[]
  feedback      EventFeedback[]
  statistic     EventStatistic?
  logs          EventLog[]

  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@index([collegeId])
  @@index([startDatetime])
  @@map("events")
}

model EventRegistration {
  id        String   @id @default(uuid())
  eventId   String   @map("event_id")
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  studentId String?  @map("student_id")
  student   Student? @relation(fields: [studentId], references: [id], onDelete: SetNull)
  status    String   @default("REGISTERED") // REGISTERED | ATTENDED | CANCELLED
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([eventId, userId])
  @@map("event_registrations")
}


// ────────────────────────────────────────────────────────────────
// Events (Part 11) - New Models
// ────────────────────────────────────────────────────────────────

enum EventStatus {
  DRAFT
  PUBLISHED
  REGISTRATION_OPEN
  REGISTRATION_CLOSED
  ONGOING
  COMPLETED
  CANCELLED
}

model EventCategory {
  id        String    @id @default(uuid())
  name      String    @unique
  events    Event[]
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@map("event_categories")
}

model EventParticipant {
  id                 String    @id @default(uuid())
  eventId            String    @map("event_id")
  event              Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  studentId          String    @map("student_id")
  student            Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teamName           String?   @map("team_name")
  leader             Boolean   @default(false)
  registrationNumber String?   @map("registration_number")
  deletedAt          DateTime? @map("deleted_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  @@map("event_participants")
}

model EventGallery {
  id        String    @id @default(uuid())
  eventId   String    @map("event_id")
  event     Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  mediaUrl  String    @map("media_url")
  mediaType String    @map("media_type") // e.g. "IMAGE", "VIDEO", "POSTER"
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@map("event_gallery")
}

model EventDocument {
  id        String    @id @default(uuid())
  eventId   String    @map("event_id")
  event     Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name      String
  fileUrl   String    @map("file_url")
  fileType  String    @map("file_type") // e.g. "RULES", "SCHEDULE", "RESULT", "CERTIFICATE"
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@map("event_documents")
}

model EventAttendance {
  id           String    @id @default(uuid())
  eventId      String    @map("event_id")
  event        Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  studentId    String    @map("student_id")
  student      Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  status       String // "PRESENT" | "ABSENT"
  checkedInAt  DateTime? @map("checked_in_at")
  checkedOutAt DateTime? @map("checked_out_at")
  deletedAt    DateTime? @map("deleted_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@map("event_attendance")
}

model EventResult {
  id           String    @id @default(uuid())
  eventId      String    @map("event_id")
  event        Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  studentId    String    @map("student_id")
  student      Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  position     String // "WINNER", "RUNNER_UP", "THIRD", "PARTICIPATION"
  score        Float?
  judgeRemarks String?   @map("judge_remarks")
  deletedAt    DateTime? @map("deleted_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@map("event_results")
}

model EventCertificate {
  id              String    @id @default(uuid())
  eventId         String    @map("event_id")
  event           Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  studentId       String    @map("student_id")
  student         Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  certificateType String    @map("certificate_type") // "PARTICIPATION", "WINNER", "VOLUNTEER", "ORGANIZER"
  certificateUrl  String    @map("certificate_url")
  issuedAt        DateTime  @default(now()) @map("issued_at")
  deletedAt       DateTime? @map("deleted_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@map("event_certificates")
}

model EventFeedback {
  id        String    @id @default(uuid())
  eventId   String    @map("event_id")
  event     Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  studentId String    @map("student_id")
  student   Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  rating    Int
  comment   String?
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@map("event_feedback")
}

model EventStatistic {
  id                   String    @id @default(uuid())
  eventId              String    @unique @map("event_id")
  event                Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  registrationCount    Int       @default(0) @map("registration_count")
  participationCount   Int       @default(0) @map("participation_count")
  attendanceCount      Int       @default(0) @map("attendance_count")
  completionPercentage Float?    @map("completion_percentage")
  certificatesIssued   Int       @default(0) @map("certificates_issued")
  deletedAt            DateTime? @map("deleted_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  @@map("event_statistics")
}

model EventLog {
  id        String   @id @default(uuid())
  eventId   String   @map("event_id")
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  action    String // "CREATED", "UPDATED", "PUBLISHED", "REGISTRATION", "CANCELLED", "COMPLETED"
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  details   String?
  timestamp DateTime @default(now())

  @@map("event_logs")
}
